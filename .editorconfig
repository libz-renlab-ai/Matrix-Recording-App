root = true

[*]
indent_style = space
indent_size = 2
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.md]
trim_trailing_whitespace = false

[Makefile]
indent_style = tab

[*.{kt,kts,java,gradle}]
indent_size = 4

[*.{swift,m,h}]
indent_size = 4

[*.dart]
indent_size = 2

[*.py]
indent_size = 4
